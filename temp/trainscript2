--[[
╔══════════════════════════════════════════════════════════════════╗
║             ROLLER COASTER SYSTEM — LEAD CAR SERVER              ║
║         Place this Script inside the Train's Model               ║
╚══════════════════════════════════════════════════════════════════╝

  Architecture:
    Workspace
    └── CoasterTrain (Model)
        ├── LeadCar (BasePart)  ← the front car; raycasts downward
        ├── LeadCarServer (this Script)
        └── Events/
            ├── StationReached  (BindableEvent)  → fires OUT to StationController
            └── ReleaseFromStation (BindableEvent) ← fires IN to resume train
--]]

------------------------------------------------------------------------
-- CONFIGURATION TABLE
------------------------------------------------------------------------
local CONFIG = {
    -- Physics
    Gravity         = 1.0,   -- multiplier applied to gravity-driven acceleration (1 = Earth-like)
    MaxGravitySpeed = 120,   -- studs/sec hard cap on freefall/hill speed
    FrictionCoeff   = 0.02,  -- rolling-resistance fraction per second (reduces speed on flat/up track)

    -- Chain Lift
    ChainSpeed      = 14,    -- studs/sec while on chain-lift track

    -- Brake Zones
    BrakeForce      = 4.0,   -- interpolation rate (higher = snappier deceleration), studs/sec²
    TargetBrakeSpeed = 0,    -- default target speed for brake track (0 = full stop)

    -- Slow Zone
    SlowZoneSpeed   = 8,     -- studs/sec cap while in slow-zone track

    -- Station
    StationWaitEvent    = "ReleaseFromStation",  -- name of BindableEvent to wait on
    --
    -- FIX: After the station releases the train, ignore station-colored track
    -- for this many seconds so the train can physically escape the zone before
    -- it would be eligible to stop again.  Tune to (station_length / SlowZoneSpeed).
    StationCooldownTime = 6,  -- seconds of immunity after a release

    -- Audio (replace 0 with real asset IDs)
    ChainSoundID    = 0,     -- rbxassetid for chain-lift rattle
    TrackSoundID    = 0,     -- rbxassetid for wheel-on-track ambient

    -- Raycast
    RayLength       = 8,     -- studs downward to scan for track (increased to be safe)

    --[[
        FIX — Ride Height vs. Ray Origin Offset (two separate concerns)
        ────────────────────────────────────────────────────────────────
        RayOriginUpOffset : how far ABOVE the PrimaryPart center the ray
            starts, so the origin is never inside track geometry.
            Keep this at 1–2 studs; it does NOT affect car height.

        CarRideHeight : the true distance (in studs) from the rail surface
            to the PrimaryPart center.  This is what actually positions the
            car vertically.
              • 0  → PrimaryPart center sits exactly on the rail surface
              • positive value → PrimaryPart floats that many studs above it
            Measure in Studio: drag the train until the wheels *look* correct,
            then read the gap between the bottom of the wheel and the rail.
            Set CarRideHeight to the distance from the rail to the PrimaryPart
            centre (usually half the wheel diameter, or 0 if the PrimaryPart
            IS at rail level).
    --]]
    RayOriginUpOffset = 2,   -- studs above PrimaryPart to start the downward ray
    CarRideHeight     = 0,   -- studs above rail surface where PrimaryPart center should sit
                             -- ← TUNE THIS: set to half your wheel radius if wheels sink in

    -- Orientation smoothing (0–1; lower = smoother turns, higher = snappier)
    OrientAlpha     = 0.25,

    -- Tick rate
    PhysicsStepRate = 0.03,  -- seconds between physics updates (~33 Hz)

    -- Spawn / Depot Teleport
    SpawnTrackNumber  = 1,             -- ← CHANGE THIS to pick your lane
    SpawnTrackFolder  = "Tracks",      -- folder in Workspace holding Track1, Track2 …
    SpawnHeightOffset = 0,             -- fine-tune nudge in studs (0 = PrimaryPart center lands exactly on marker)
    SpawnFaceForward  = true,          -- align train heading to marker heading

    -- Color → Zone mapping  (BrickColor Name → zone string)
    DefaultColors = {
        ["Maroon"]       = "Station",   -- station / boarding zone
        ["Really red"]   = "SlowZone",  -- trim brake / slow section
        ["Really blue"]  = "ChainLift", -- chain-lift hill
        ["Lime green"]   = "Brake",     -- brake run (full deceleration)
        ["Lily white"]   = "Normal",    -- regular track (physics-driven)
    },
}

------------------------------------------------------------------------
-- SERVICES & REFERENCES
------------------------------------------------------------------------
local RunService    = game:GetService("RunService")

local trainModel    = script.Parent                          -- the coaster Model

-- Resolve LeadCar to an actual BasePart.
local function resolveLeadCarPart()
    local raw = trainModel:WaitForChild("LeadCar")

    if raw:IsA("BasePart") then
        return raw
    elseif raw:IsA("Model") then
        if raw.PrimaryPart then
            warn("[CoasterSystem] LeadCar is a Model — using its PrimaryPart: " .. raw.PrimaryPart.Name)
            return raw.PrimaryPart
        end
        for _, child in raw:GetDescendants() do
            if child:IsA("BasePart") then
                warn("[CoasterSystem] LeadCar Model has no PrimaryPart — falling back to first BasePart: " .. child.Name)
                return child
            end
        end
    end

    error("[CoasterSystem] SETUP ERROR: Could not find a BasePart for LeadCar.\n" ..
          "  Fix: Make sure 'LeadCar' is a BasePart (or a Model with its PrimaryPart set)\n" ..
          "  inside the '" .. trainModel.Name .. "' Model.", 2)
end

local leadCar = resolveLeadCarPart()

-- BindableEvents
local eventsFolder      = trainModel:WaitForChild("Events")
local stationReachedEvt = eventsFolder:WaitForChild("StationReached")
local releaseEvt        = eventsFolder:WaitForChild("ReleaseFromStation")

------------------------------------------------------------------------
-- SOUND SETUP
------------------------------------------------------------------------
local function makeSound(parent, assetId, looped)
    local s = Instance.new("Sound")
    s.SoundId    = "rbxassetid://" .. assetId
    s.Looped     = looped
    s.RollOffMaxDistance = 80
    s.Parent     = parent
    return s
end

local chainSound = makeSound(leadCar, CONFIG.ChainSoundID, true)
local trackSound = makeSound(leadCar, CONFIG.TrackSoundID, true)

------------------------------------------------------------------------
-- RAYCAST SETUP
------------------------------------------------------------------------
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
rayParams.FilterDescendantsInstances = { trainModel }

------------------------------------------------------------------------
-- STATE
------------------------------------------------------------------------
local state = {
    speed              = 0,        -- current speed studs/sec
    zone               = "Normal", -- active zone string
    atStation          = false,    -- true while waiting at station
    paused             = false,    -- halts the physics loop
    --
    -- FIX: timestamp of the last station release; used to enforce
    -- StationCooldownTime so the train can't immediately re-dock.
    stationReleasedAt  = -math.huge,  -- os.clock() value; -inf means "never released yet"
}

------------------------------------------------------------------------
-- RAYCAST HELPER
-- Origin starts RayOriginUpOffset studs ABOVE the PrimaryPart center so
-- the ray never begins inside track geometry.
------------------------------------------------------------------------
local function castTrackRay()
    local totalRayLength = CONFIG.RayLength + CONFIG.RayOriginUpOffset
    local origin    = leadCar.CFrame.Position + Vector3.new(0, CONFIG.RayOriginUpOffset, 0)
    local direction = Vector3.new(0, -totalRayLength, 0)
    return workspace:Raycast(origin, direction, rayParams)
end

------------------------------------------------------------------------
-- SLOPE ACCELERATION
------------------------------------------------------------------------
local function slopeAcceleration(surfaceNormal, forwardDir)
    if not surfaceNormal then return 0 end
    local g = 196.2 * 0.8 * CONFIG.Gravity

    local tangent = forwardDir - surfaceNormal * forwardDir:Dot(surfaceNormal)
    if tangent.Magnitude < 0.001 then return 0 end
    tangent = tangent.Unit

    return g * Vector3.new(0, -1, 0):Dot(tangent)
end

------------------------------------------------------------------------
-- TRACK SNAP MOVEMENT
-- FIX: Uses CONFIG.CarRideHeight (not RayOriginUpOffset) to lift the
-- PrimaryPart above the rail surface, so the two concerns are decoupled.
------------------------------------------------------------------------
local function applyMovement(dt, surfaceNormal, hitPos)
    local primary = trainModel.PrimaryPart
    if not primary then
        if not applyMovement._warned then
            warn("[CoasterSystem] No PrimaryPart set — set it for track-snapping.")
            applyMovement._warned = true
        end
        leadCar.CFrame = leadCar.CFrame + leadCar.CFrame.LookVector * (state.speed * dt)
        return
    end

    local currentCF   = primary.CFrame
    local currentLook = currentCF.LookVector

    if surfaceNormal and hitPos then
        -- 1. Project look onto surface plane → along-track tangent
        local tangent = currentLook - surfaceNormal * currentLook:Dot(surfaceNormal)
        if tangent.Magnitude < 0.001 then tangent = currentLook end
        tangent = tangent.Unit

        -- 2. Advance position along the tangent
        --    FIX: lift by CarRideHeight (true wheel-to-axle distance),
        --         NOT by RayOriginUpOffset (which is just a ray-start bias).
        local newPos = hitPos
            + tangent * (state.speed * dt)
            + surfaceNormal * CONFIG.CarRideHeight

        -- 3. Build surface-aligned CFrame
        local right = tangent:Cross(surfaceNormal)
        if right.Magnitude < 0.001 then right = currentCF.RightVector end
        right = right.Unit
        local targetCF = CFrame.fromMatrix(newPos, right, surfaceNormal)

        -- 4. Slerp orientation, snap position
        local smoothCF = currentCF:Lerp(targetCF, CONFIG.OrientAlpha)
        local finalCF  = CFrame.fromMatrix(newPos, smoothCF.RightVector, smoothCF.UpVector)

        trainModel:SetPrimaryPartCFrame(finalCF)
    else
        -- No track below — push forward in air
        local newCF = currentCF + currentLook * (state.speed * dt)
        trainModel:SetPrimaryPartCFrame(newCF)
    end
end

------------------------------------------------------------------------
-- ZONE HANDLERS
------------------------------------------------------------------------
local handlers = {}

function handlers.Normal(dt, surfaceNormal)
    local slopeAcc = slopeAcceleration(surfaceNormal, leadCar.CFrame.LookVector)
    local friction  = CONFIG.FrictionCoeff * state.speed
    state.speed     = math.clamp(state.speed + (slopeAcc - friction) * dt, 0, CONFIG.MaxGravitySpeed)

    if not trackSound.IsPlaying then trackSound:Play() end
    if chainSound.IsPlaying     then chainSound:Stop() end
end

function handlers.ChainLift(dt, _)
    local alpha = math.min(CONFIG.BrakeForce * dt, 1)
    state.speed = state.speed + (CONFIG.ChainSpeed - state.speed) * alpha

    if not chainSound.IsPlaying then chainSound:Play() end
    if trackSound.IsPlaying     then trackSound:Stop() end
end

function handlers.Brake(dt, _)
    local alpha = math.min(CONFIG.BrakeForce * dt, 1)
    state.speed = state.speed + (CONFIG.TargetBrakeSpeed - state.speed) * alpha
    if state.speed <= 0.05 then state.speed = 0 end

    if not trackSound.IsPlaying then trackSound:Play() end
    if chainSound.IsPlaying     then chainSound:Stop() end
end

function handlers.SlowZone(dt, surfaceNormal)
    handlers.Normal(dt, surfaceNormal)
    state.speed = math.min(state.speed, CONFIG.SlowZoneSpeed)
end

--[[
    FIX — Station handler rewrite
    ─────────────────────────────
    Problem 1 (re-catching):
        After ReleaseFromStation fires, the train is still physically inside
        the station-colored track zone.  On the very next physics tick the
        handler fires again, sets atStation = true, and re-parks the train.

    Fix:
        Record os.clock() into state.stationReleasedAt when released.
        At the TOP of the handler, bail out early if we are within
        StationCooldownTime seconds of the last release.  This gives the
        train enough time to travel out of the colored zone before it is
        eligible to stop again.

    Problem 2 (speed on exit):
        Original code set state.speed = CONFIG.SlowZoneSpeed directly after
        the release — correct intent, but the outer physics loop immediately
        calls handlers.Station again (because the zone is still "Station"),
        which calls task.spawn again.  The cooldown above prevents that.
        Once the cooldown expires and the train is physically past the station
        zone, normal zone handlers take over naturally.
--]]
function handlers.Station(_dt, _normal)
    -- Cooldown guard: ignore this zone for StationCooldownTime seconds after release
    if os.clock() - state.stationReleasedAt < CONFIG.StationCooldownTime then
        -- Still in cooldown — treat like a SlowZone so the train keeps moving out
        handlers.SlowZone(_dt, _normal)
        return
    end

    -- Already parked and waiting — do nothing; the spawned thread handles release
    if state.atStation then return end

    -- Park the train
    state.atStation = true
    state.speed     = 0
    chainSound:Stop()
    trackSound:Stop()

    print(("[CoasterSystem] Train '%s' arrived at Station"):format(trainModel.Name))
    stationReachedEvt:Fire(trainModel.Name)

    -- Wait for release in its own thread so the physics loop stays non-blocking
    task.spawn(function()
        local released = false
        local conn = releaseEvt.Event:Connect(function()
            released = true
        end)
        while not released do
            task.wait()
        end
        conn:Disconnect()

        -- Record release time BEFORE clearing atStation so the cooldown
        -- guard is in place from the very first tick after we resume.
        state.stationReleasedAt = os.clock()
        state.atStation         = false
        state.speed             = CONFIG.SlowZoneSpeed  -- ease out of station gently

        print(("[CoasterSystem] Train '%s' released from Station — cooldown active for %.1f s")
            :format(trainModel.Name, CONFIG.StationCooldownTime))
    end)
end

------------------------------------------------------------------------
-- MAIN PHYSICS LOOP
------------------------------------------------------------------------
local lastTime = os.clock()

local function physicsLoop()
    while not state.paused do
        local now = os.clock()
        local dt  = math.min(now - lastTime, 0.1)
        lastTime  = now

        -- Cast ray and read zone + surface data
        local result      = castTrackRay()
        local zone        = "Normal"
        local surfNormal  = nil
        local hitPos      = nil

        if result and result.Instance then
            zone       = CONFIG.DefaultColors[result.Instance.BrickColor.Name] or "Normal"
            surfNormal = result.Normal
            hitPos     = result.Position
        end

        -- Log zone changes for debugging
        if zone ~= state.zone then
            print(("[CoasterSystem] Zone changed: %s → %s"):format(state.zone, zone))
            state.zone = zone
        end

        -- Update speed via zone handler
        local handler = handlers[zone] or handlers.Normal
        handler(dt, surfNormal)

        -- Move & snap train (skip positional move while parked)
        if not state.atStation then
            applyMovement(dt, surfNormal, hitPos)
        end

        task.wait(CONFIG.PhysicsStepRate)
    end
end

------------------------------------------------------------------------
-- STARTUP TELEPORT
------------------------------------------------------------------------
local function findSpawnMarker(trackNumber)
    local markerName = "Track" .. tostring(trackNumber)

    if CONFIG.SpawnTrackFolder ~= "" then
        local folder = workspace:FindFirstChild(CONFIG.SpawnTrackFolder)
        if folder then
            local marker = folder:FindFirstChild(markerName)
            if marker then return marker end
            warn(("[CoasterSystem] Spawn marker '%s' not found inside folder '%s' — falling back to full Workspace search.")
                :format(markerName, CONFIG.SpawnTrackFolder))
        else
            warn(("[CoasterSystem] SpawnTrackFolder '%s' not found in Workspace — falling back to full Workspace search.")
                :format(CONFIG.SpawnTrackFolder))
        end
    end

    local marker = workspace:FindFirstChild(markerName, true)
    if marker then
        warn(("[CoasterSystem] Found '%s' via recursive search — consider placing it in '%s' for clarity.")
            :format(markerName, CONFIG.SpawnTrackFolder))
    end
    return marker
end

local function getMarkerCFrame(marker)
    if marker:IsA("BasePart") then
        return marker.CFrame
    elseif marker:IsA("Model") then
        local pp = marker.PrimaryPart
        if pp then return pp.CFrame end
        for _, d in marker:GetDescendants() do
            if d:IsA("BasePart") then return d.CFrame end
        end
    end
    return nil
end

local function teleportToSpawnTrack()
    local trackNum = CONFIG.SpawnTrackNumber
    print(("[CoasterSystem] Teleporting train '%s' to Track%d …"):format(trainModel.Name, trackNum))

    local marker = findSpawnMarker(trackNum)
    if not marker then
        warn(("[CoasterSystem] SPAWN FAILED — no marker named 'Track%d' found. Train stays on depot.")
            :format(trackNum))
        return
    end

    local markerCF = getMarkerCFrame(marker)
    if not markerCF then
        warn(("[CoasterSystem] SPAWN FAILED — marker 'Track%d' has no readable CFrame."):format(trackNum))
        return
    end

    local primary = trainModel.PrimaryPart or leadCar

    local spawnCF
    if CONFIG.SpawnFaceForward then
        spawnCF = markerCF
    else
        spawnCF = CFrame.new(markerCF.Position)
            * CFrame.fromMatrix(Vector3.zero,
                primary.CFrame.RightVector,
                primary.CFrame.UpVector)
    end

    if CONFIG.SpawnHeightOffset ~= 0 then
        spawnCF = spawnCF + markerCF.UpVector * CONFIG.SpawnHeightOffset
    end

    if trainModel.PrimaryPart then
        trainModel:SetPrimaryPartCFrame(spawnCF)
        print(("[CoasterSystem] Train '%s' centered on Track%d — PrimaryPart at %s")
            :format(trainModel.Name, trackNum, tostring(spawnCF.Position)))
    else
        leadCar.CFrame = spawnCF
        warn("[CoasterSystem] No PrimaryPart set — only LeadCar was moved. Set PrimaryPart to the midwheel part for accurate centering.")
    end

    state.speed = CONFIG.SlowZoneSpeed
end

------------------------------------------------------------------------
-- RUN STARTUP SEQUENCE
------------------------------------------------------------------------
print(("[CoasterSystem] LeadCarServer initialised on train '%s'"):format(trainModel.Name))

task.wait(3)

teleportToSpawnTrack()

trackSound:Play()

task.spawn(physicsLoop)