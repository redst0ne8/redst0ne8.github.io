local coaster = workspace["Eclipse"] -- Name of compiled coaster in workspace
local startpiece = coaster.Track1 -- Change to starting piece of train, in this case my station. It doesn't have to exist yet, but it will. TrackNumber script said so.

local TwoWheels = false -- If each car has 2 wheel sets (Like wooden train) then set this to true.
local MovingHarnesses = false -- If your train has moving harnesses, set this to true.
--Note: Harnesses MUST be set up in this way: [All names apart from 'Car' and 'Train' MUST be exact]
--[[
    Train
      -HarnessEvent (BindableEvent)
      -HarnessOpen (BoolValue, set to false)
      -Car
          -Harness (Model)
              -Open (BasePart)
              -Closed (BasePart)
              -Moving (Model)
                  -Primary (BasePart)
]]
--Any parts in 'Moving' will move with the harness.
--The harness will move with 'Primary' moving to Open/Closed depending on the state of the harness.
--Whatever you do, DO NOT move the train with harnesses open!

-- Oh and don't forget to make the tracker parts invisible

